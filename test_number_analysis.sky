function sayı_analizi(sayi: int)
    string sonuç = ""
    if sayi > 0:
        sonuç = sonuç + "Pozitif "
    elif sayi < 0:
        sonuç = sonuç + "Negatif "
    else:
        sonuç = sonuç + "Sıfır "
    
    if sayi % 2 == 0:
        sonuç = sonuç + "Çift"
    else:
        sonuç = sonuç + "Tek"
    
    return sonuç

print("5: " + sayı_analizi(5))
print("8: " + sayı_analizi(8))
print("0: " + sayı_analizi(0))
print("-3: " + sayı_analizi(-3))
