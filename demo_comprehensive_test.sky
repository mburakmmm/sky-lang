# Kapsamlı Feature Test
print("🚀 Sky Language - Kapsamlı Feature Test Başlıyor...")

# 1. Temel Syntax
print("📝 1. Temel Syntax Test")
int sayı = 42
string isim = "Sky"
bool aktif = true
print("Sayı: " + sayı + ", İsim: " + isim + ", Aktif: " + aktif)

# 2. Fonksiyonlar
print("🔧 2. Fonksiyon Test")
function selam(ad: string)
  return "Merhaba " + ad

var mesaj = selam("Sky")
print("Fonksiyon sonucu: " + mesaj)

# 3. Async/Await
print("⚡ 3. Async/Await Test")
async function async_test()
  return "Async çalışıyor!"

var async_result = async_test()
print("Async sonucu: " + async_result)

# 4. Coroutines
print("🔄 4. Coroutine Test")
coop function say(n: int)
  int i = 1
  while i <= n
    yield "Sayı: " + i
    i = i + 1
  return "Bitti"

var coroutine = say(3)
print("Coroutine sonucu: " + coroutine)

# 5. Import System
print("📦 5. Import System Test")
import math
var sqrt_result = math.sqrt(16)
print("Math.sqrt(16) = " + sqrt_result)

# 6. Python Bridge
print("🐍 6. Python Bridge Test")
var py_math = python_import("math")
print("Python math modülü import edildi!")

# 7. JS Bridge
print("🟨 7. JS Bridge Test")
var js_func = js_eval("(x) => x * 2")
var js_result = js_func(21)
print("JS sonucu: " + js_result)

# 8. IO Operations
print("📚 8. IO Operations Test")
write("IO Test: ")
print("Print çalışıyor!")
var formatted = format("Format test: {}", "Sky")
print(formatted)
var text_len = len("Sky Language")
print("String uzunluğu: " + text_len)

# 9. Time Operations
print("⏰ 9. Time Operations Test")
var current_time = now()
print("Şu anki zaman: " + current_time)
sleep(100)
print("Sleep tamamlandı!")

# 10. HTTP Operations
print("🌐 10. HTTP Operations Test")
var http_response = http.get("https://example.com")
print("HTTP GET tamamlandı!")

print("✅ Sky Language - Kapsamlı Feature Test Bitti!")
print("🎉 Tüm özellikler başarıyla test edildi!")
