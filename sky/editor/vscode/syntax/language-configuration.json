{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(function|async\\s+function|coop\\s+function|if|elif|else|for|while|try|except|finally|class|def|with)\\b.*:",
    "decreaseIndentPattern": "^\\s*(elif|else|except|finally)\\b"
  },
  "wordPattern": "\\b[a-zA-Z_][a-zA-Z0-9_çğıöşüÇĞIÖŞÜ]*\\b",
  "folding": {
    "markers": {
      "start": "^\\s*#\\s*region\\b",
      "end": "^\\s*#\\s*endregion\\b"
    }
  }
}
