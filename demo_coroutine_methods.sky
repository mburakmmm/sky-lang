# Coroutine Methods Test
print("🔄 Coroutine Methods Test Başlıyor...")

# Coop function tanımlama
coop function say(etiket: string, n: int)
  int i = 1
  while i <= n
    yield etiket + ": " + i
    i = i + 1
  return "bitti"

# Coroutine oluşturma
var c = say("num", 2)
print("✅ Coroutine oluşturuldu")

# Coroutine metodlarını test et
print("🔍 Coroutine metodları test ediliyor...")

